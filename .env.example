# ============================================
# Facebook OAuth Credentials
# ============================================
# Get these from: https://developers.facebook.com/apps/
# 1. Create a new app (Consumer type)
# 2. Add Facebook Login product
# 3. Configure OAuth redirect URI: http://localhost:5001/api/auth/facebook/callback

FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# ============================================
# Session Configuration
# ============================================
# Generate a random string for production
# Use: openssl rand -base64 32
SESSION_SECRET=your-random-session-secret-here

# Session expiration time in days (default: 7)
# Examples:
# - 1 day: SESSION_EXPIRE_DAYS=1
# - 7 days: SESSION_EXPIRE_DAYS=7
# - 30 days: SESSION_EXPIRE_DAYS=30
SESSION_EXPIRE_DAYS=7

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# For local development with network access:
ALLOWED_ORIGINS=http://localhost:5001,http://192.168.1.107:5001

# For production deployment:
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ============================================
# Environment
# ============================================
NODE_ENV=production

# ============================================
# Setup Instructions
# ============================================
#
# 1. Create Facebook App:
#    - Go to https://developers.facebook.com/apps/
#    - Click "Create App" → Select "Consumer" type
#    - Add "Facebook Login" product
#    - Set App Domains: localhost
#    - Set Site URL: http://localhost:5001
#    - Set Valid OAuth Redirect URIs: http://localhost:5001/api/auth/facebook/callback
#    - Copy App ID and App Secret to this file
#
# 2. Generate Session Secret:
#    - Run: openssl rand -base64 32
#    - Copy output to SESSION_SECRET
#
# 3. Configure Session Duration:
#    - Set SESSION_EXPIRE_DAYS to desired number of days
#    - Default is 7 days if not specified
#    - Options: 1 (high security), 7 (balanced), 30 (convenient)
#
# 4. Configure CORS Origins:
#    - Add your local IP for network access from other devices
#    - Format: http://IP:5001 (comma-separated, no spaces)
#    - Example: http://localhost:5001,http://192.168.1.107:5001
#
# 5. Copy this file to .env:
#    - cp .env.example .env
#    - Fill in the actual values
#
# 6. Restart the application:
#    - docker-compose down
#    - docker-compose up -d
