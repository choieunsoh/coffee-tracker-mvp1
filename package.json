{
  "name": "coffee-tracker-mvp",
  "version": "1.4.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "Coffee Tracker MVP - Simple coffee tracking with JSON file storage and Express backend",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "start": "node server.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:restart": "docker-compose restart",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --rmi all",
    "docker:rebuild": "docker-compose down -v && docker-compose build --no-cache && docker-compose up -d",
    "deploy:patch": "bash deploy.sh patch",
    "deploy:minor": "bash deploy.sh minor",
    "deploy:major": "bash deploy.sh major",
    "deploy": "bash deploy.sh patch",
    "generate-api-key": "node -e \"const crypto = require('crypto'); const randomPart = crypto.randomBytes(32).toString('base64').replace(/[+/]/g, '').substring(0, 36); console.log('tod_' + randomPart);\"",
    "docker:secure": "API_KEY=tod_JrTWmGd1As9iQFP6I2FWlJz0sDaAGPMbBF8k docker-compose up -d --build"
  },
  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^6.4.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.19.0"
  }
}
