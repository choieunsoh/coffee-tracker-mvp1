{
  "name": "coffee-tracker-mvp",
  "version": "1.5.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "Coffee Tracker MVP - Simple coffee tracking with JSON file storage and Express backend",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "start": "node server.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:restart": "docker-compose restart",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --rmi all",
    "docker:rebuild": "docker-compose down -v && docker-compose build --no-cache && docker-compose up -d",
    "deploy:patch": "bash deploy.sh patch",
    "deploy:minor": "bash deploy.sh minor",
    "deploy:major": "bash deploy.sh major",
    "deploy": "bash deploy.sh patch",
    "generate:api-key": "openssl rand -base64 24 | tr -d '/+' | head -c 32 | sed 's/^/tod_/'",
    "generate:session-secret": "openssl rand -hex 32"
  },
  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^6.4.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express-session": "^1.18.2",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.19.0"
  }
}
