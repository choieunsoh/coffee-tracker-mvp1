{
  "permissions": {
    "deny": [
      "Read(*.env)",
      "Read(*.env.*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(*secret*)",
      "Read(*secrets*)",
      "Read(*credentials*)",
      "Read(*creds*)",
      "Read(*password*)",
      "Read(*api-key*)",
      "Read(*apikey*)",
      "Read(*private-key*)",
      "Read(*privatekey*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(*.cert)",
      "Read(*.crt)",
      "Read(*.keystore)",
      "Read(*.jks)",
      "Read(*auth.json)",
      "Read(*.aws/*)",
      "Read(*.ssh/*)",
      "Read(*.azure/*)",
      "Read(*.config/*secret*)",
      "Write(*.env)",
      "Write(*.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(*secret*)",
      "Write(*secrets*)",
      "Write(*credentials*)",
      "Write(*creds*)",
      "Write(*password*)",
      "Write(*api-key*)",
      "Write(*apikey*)",
      "Write(*private-key*)",
      "Write(*privatekey*)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(*.p12)",
      "Write(*.pfx)",
      "Write(*auth.json)",
      "Bash(cat *env*)",
      "Bash(cat *.env)",
      "Bash(cat .env)",
      "Bash(cat .env.*)",
      "Bash(cat *secret*)",
      "Bash(cat *credentials*)",
      "Bash(less *env*)",
      "Bash(less *secret*)",
      "Bash(more *env*)",
      "Bash(more *secret*)",
      "Bash(vi *env*)",
      "Bash(vi *secret*)",
      "Bash(vim *env*)",
      "Bash(vim *secret*)",
      "Bash(nano *env*)",
      "Bash(nano *secret*)",
      "Bash(head *env*)",
      "Bash(head *secret*)",
      "Bash(tail *env*)",
      "Bash(tail *secret*)",
      "Bash(grep -i password *)",
      "Bash(grep -i secret *)",
      "Bash(grep -i apikey *)",
      "Bash(grep -i api-key *)"
    ],
    "allow": ["Read(*)", "Write(*)", "Glob(*)", "Grep(*)"],
    "ask": ["Bash(git commit:*)", "Bash(git merge:*)", "Bash(git push:*)"]
  }
}
